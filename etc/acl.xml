<?xml version="1.0"?>
<!--
 * Pigeon Express Shipping - ACL for viewing/editing configuration.
 * Follows Magento pattern: config under Stores > Configuration.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Sales::sales">
                    <resource id="Magento_Sales::sales_operation">
                        <resource id="PigeonExpress_Shipping::send_shipment"
                                  title="Send Pigeon Express Shipment"
                                  translate="title"
                                  sortOrder="100" />
                    </resource>
                </resource>
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="PigeonExpress_Shipping::config_pigeonexpress"
                                      title="Pigeon Express Shipping Configuration"
                                      translate="title"
                                      sortOrder="200">
                                <resource id="PigeonExpress_Shipping::sync"
                                          title="Schedule Location Sync"
                                          translate="title" />
                            </resource>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
