<?xml version="1.0"?>
<!--
 * Pigeon Express: persist delivery type and selected Office/APS in quote/order.
 * DB → autocomplete → quote (extension_attributes) → order (extension_attributes).
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Api/etc/extension_attributes.xsd">
    <!-- Checkout payload: frontend sends these when saving shipping information -->
    <extension_attributes for="Magento\Checkout\Api\Data\ShippingInformationInterface">
        <attribute code="pigeonexpress_delivery_type" type="string"/>
        <attribute code="pigeonexpress_location_id" type="string"/>
        <attribute code="pigeonexpress_location_name" type="string"/>
        <attribute code="pigeonexpress_location_address" type="string"/>
        <attribute code="pigeonexpress_instructions" type="string"/>
        <attribute code="pigeonexpress_delivery_price" type="double"/>
    </extension_attributes>
    <!-- Quote shipping address: stored so it survives reload and is available for collectRates -->
    <extension_attributes for="Magento\Quote\Api\Data\AddressInterface">
        <attribute code="pigeonexpress_delivery_type" type="string"/>
        <attribute code="pigeonexpress_location_id" type="string"/>
        <attribute code="pigeonexpress_location_name" type="string"/>
        <attribute code="pigeonexpress_location_address" type="string"/>
        <attribute code="pigeonexpress_instructions" type="string"/>
        <attribute code="pigeonexpress_delivery_price" type="double"/>
    </extension_attributes>
    <!-- Order shipping address: persisted when order is placed -->
    <extension_attributes for="Magento\Sales\Api\Data\OrderAddressInterface">
        <attribute code="pigeonexpress_delivery_type" type="string"/>
        <attribute code="pigeonexpress_location_id" type="string"/>
        <attribute code="pigeonexpress_location_name" type="string"/>
        <attribute code="pigeonexpress_location_address" type="string"/>
        <attribute code="pigeonexpress_instructions" type="string"/>
        <attribute code="pigeonexpress_delivery_price" type="double"/>
    </extension_attributes>
</config>
